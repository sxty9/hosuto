#!/usr/bin/env bash
# service — single-file CLI for a holistic service (the holistic-service-template).
# Owns one-time bootstrap (`init`), install/repair (`setup`) and lifecycle. The systemd
# unit, Caddy route and the rights drop-in are all generated inline by `setup` — this
# script is their source of truth (no separate install script, no deploy/ tree).
#
# The service id is the single source of truth in permissions/<id>.json, so this CLI
# auto-detects it from that filename and never hardcodes a name. `init` renames the
# placeholder everywhere; from then on every command derives its paths from the id.
#
# hosuto adds a privileged layer to the template, and it is installed from here too:
#   sbin/hosuto-server  the ONLY thing hosutod may sudo to. Re-derives every guard itself.
#   sbin/hosuto-stop    ExecStop: an RCON /stop, so a world is saved before it dies.
#   sbin/hosuto-run     ExecStart: turns <dir>/exec.argv into the JVM process.
#   systemd/hosuto-mc@.service  the per-server template unit (instance = <owner>-<slug>).
#   mc-router           one public 25565 for every server, routed by hostname.

set -euo pipefail

TEMPLATE_VERSION="0.1.0"
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ORIG_ARGS=("$@")

# ── service id (the manifest filename stem == the holistic service id) ────────────
detect_service_id() {
  local f
  for f in "$REPO_ROOT"/permissions/*.json; do
    [ -e "$f" ] || continue
    basename "$f" .json
    return 0
  done
  return 1
}
: "${SERVICE_ID:=}"
[ -n "$SERVICE_ID" ] || SERVICE_ID="$(detect_service_id || true)"

# ── config (override via env) ─────────────────────────────────────────────────────
: "${HOLISTIC_REPO:=}"                                  # holistic repo; autodetected if empty
: "${SERVICE_APP:=/opt/${SERVICE_ID:-service}}"         # install prefix (binary lives here)
: "${SERVICE_USER:=${SERVICE_ID:-service}}"             # unprivileged system user
: "${SERVICE_PORT:=8779}"                               # loopback port for the daemon (8773 is bwl-manager's)
: "${SERVICE_ADMIN_GROUP:=sudo}"                        # Linux group that confers admin
: "${HOLISTIC_SECRET_FILE:=/etc/holistic/jwt-secret}"   # shared session-signing secret
: "${HOLISTIC_GROUP:=holistic}"                         # group that owns the shared secret
# Sibling services hosuto talks to machine-to-machine. Each client degrades silently when its
# secret is absent, so a host without notify or contax still runs hosuto.
: "${NOTIFY_URL:=http://127.0.0.1:8778}"
: "${NOTIFY_SECRET_FILE:=/etc/holistic/notify-secret}"
: "${CONTAX_URL:=http://127.0.0.1:8777}"
: "${CONTAX_SECRET_FILE:=/etc/holistic/icaly-contax-secret}"
# mc-router: the single public Minecraft port. It reads the hostname out of the client's handshake
# and splices the connection to the right backend, so every server shares 25565.
: "${MCROUTER_PORT:=25565}"
: "${MCROUTER_API:=127.0.0.1:25580}"                    # loopback REST API the daemon writes routes to
: "${MCROUTER_RATE_LIMIT:=20}"                          # new connections/s — see write_router_unit
: "${MCROUTER_REPO:=itzg/mc-router}"

# ── derived paths (depend on the service id) ──────────────────────────────────────
SYSTEMD_DIR="/etc/systemd/system"
UNIT="$SYSTEMD_DIR/${SERVICE_ID}.service"
CADDY_ROUTE="/etc/caddy/conf.d/${SERVICE_ID}.caddy"
PERMS_FILE="/etc/holistic/permissions.d/${SERVICE_ID}.json"
CONFIG_FILE="/etc/holistic/config.d/${SERVICE_ID}.json"
DAEMON_BIN="$SERVICE_APP/bin/${SERVICE_ID}d"
ENV_PREFIX="$(printf '%s' "${SERVICE_ID:-service}" | tr '[:lower:]' '[:upper:]')"
ADMIN_ENV="${ENV_PREFIX}_ADMIN_GROUP"
STATE_DIR="/var/lib/${SERVICE_ID}"
SERVERS_ROOT="$STATE_DIR/servers"                       # one <owner>/<slug> tree per server
ROUTES_FILE="$STATE_DIR/routes.json"                    # mc-router's persisted route table
# The privileged layer. hosutod runs unprivileged and escalates ONLY to these two (hosuto-run is
# never sudo'd — systemd execs it as the server's owner).
WRAPPER="/usr/local/sbin/${SERVICE_ID}-server"
STOP_WRAPPER="/usr/local/sbin/${SERVICE_ID}-stop"
RUN_WRAPPER="/usr/local/sbin/${SERVICE_ID}-run"
SUDOERS="/etc/sudoers.d/${SERVICE_ID}"
MC_UNIT="$SYSTEMD_DIR/${SERVICE_ID}-mc@.service"
ROUTER_BIN="$SERVICE_APP/bin/mc-router"
ROUTER_UNIT="$SYSTEMD_DIR/mc-router.service"

# ── output ────────────────────────────────────────────────────────────────────────
log()  { [ "${SERVICE_QUIET:-0}" = "1" ] || printf '[%s] %s\n' "${SERVICE_ID:-service}" "$*"; }
warn() { printf '[%s] warning: %s\n' "${SERVICE_ID:-service}" "$*" >&2; }
die()  { printf '[%s] error: %s\n' "${SERVICE_ID:-service}" "$*" >&2; exit "${2:-1}"; }

confirm() {
  [ "${SERVICE_YES:-0}" = "1" ] && return 0
  local reply
  printf '[%s] %s [y/N] ' "${SERVICE_ID:-service}" "$1" >&2
  read -r reply || return 1
  [[ "$reply" =~ ^[yY]$ ]]
}

# Re-exec under sudo, preserving env + the original argv, so users never have to type it.
needs_root() {
  [ "$(id -u)" -eq 0 ] && return 0
  command -v sudo >/dev/null || die "must run as root (sudo not found)"
  exec sudo -E "$0" "${ORIG_ARGS[@]}"
}

require_id() {
  [ -n "$SERVICE_ID" ] || die "no permissions/<id>.json found — run from the repo root" 5
}

# ── holistic repo discovery (assumes holistic is a sibling, like hostek/privleg) ──
is_holistic_repo() { [ -x "$1/holistic" ] && [ -f "$1/frontend/app/src/registry.ts" ]; }

detect_holistic_repo() {
  if [ -n "$HOLISTIC_REPO" ]; then
    is_holistic_repo "$HOLISTIC_REPO" \
      || die "HOLISTIC_REPO=$HOLISTIC_REPO is not a holistic repo (missing ./holistic or frontend)"
    ( cd "$HOLISTIC_REPO" && pwd ); return 0
  fi
  local c
  for c in "$REPO_ROOT/../holistic" /code/holistic "$HOME/holistic" /home/*/holistic; do
    [ -e "$c" ] && is_holistic_repo "$c" && { ( cd "$c" && pwd ); return 0; }
  done
  return 1
}

# ── build ───────────────────────────────────────────────────────────────────────
ensure_go() {
  command -v go >/dev/null && return 0
  log "installing Go toolchain..."
  apt-get update -qq
  apt-get install -y -qq golang-go >/dev/null
  command -v go >/dev/null || die "Go install failed" 4
}

build_daemon() {
  ensure_go
  log "building ${SERVICE_ID}d..."
  install -d -o "$SERVICE_USER" -g "$SERVICE_USER" -m 0755 "$SERVICE_APP" "$SERVICE_APP/bin"
  ( cd "$REPO_ROOT/backend" && GOCACHE="/tmp/${SERVICE_ID}-gocache" go build -o "$DAEMON_BIN" "./cmd/${SERVICE_ID}d" )
  chown -R "$SERVICE_USER:$SERVICE_USER" "$SERVICE_APP"
  # ...but not mc-router: it lives in the same tree and runs as this very account, which therefore
  # must not be able to rewrite it and wait for the next restart.
  [ -e "$ROUTER_BIN" ] && chown root:root "$ROUTER_BIN"
  return 0
}

# ── the game runtime ──────────────────────────────────────────────────────────────
# Java is not on a stock Ubuntu. versions.JavaBin globs /usr/lib/jvm for the major a given Minecraft
# version demands — 21 for 1.20.5+, 17 for 1.17–1.20.4 — so both JREs are installed and each server
# gets the right one. Headless: the desktop JRE would drag X11 onto a server.
ensure_java() {
  local pkgs=(openjdk-21-jre-headless openjdk-17-jre-headless) missing=() p
  for p in "${pkgs[@]}"; do
    dpkg-query -W -f='${Status}' "$p" 2>/dev/null | grep -q '^install ok installed$' || missing+=("$p")
  done
  [ "${#missing[@]}" -eq 0 ] && return 0
  log "installing Java runtimes (${missing[*]})..."
  apt-get update -qq
  apt-get install -y -qq "${missing[@]}" >/dev/null \
    || die "could not install ${missing[*]} — no server can run without a JRE" 4
}

# The newest linux release tarball for this architecture, resolved through the GitHub API (goreleaser
# puts the version in the filename, so there is no stable /latest/download/ URL to guess).
mcrouter_url() {
  local arch
  case "$(uname -m)" in
    x86_64 | amd64) arch='(amd64|x86_64)' ;;
    aarch64 | arm64) arch='(arm64|aarch64)' ;;
    *) return 1 ;;
  esac
  curl -fsSL --max-time 20 "https://api.github.com/repos/$MCROUTER_REPO/releases/latest" 2>/dev/null \
    | grep -oE 'https://[^"]+\.tar\.gz' \
    | grep -E "linux_${arch}\.tar\.gz$" \
    | head -n1
}

# mc-router is optional infrastructure: without it every server is still created, started and shown —
# it just has no public front door yet. So a failed download WARNS and setup continues; the daemon's
# router client is disabled-by-absence and no-ops.
ensure_mcrouter() {
  local url tmp bin
  if [ -x "$ROUTER_BIN" ]; then
    log "mc-router already installed ($ROUTER_BIN)"
  else
    command -v curl >/dev/null && command -v tar >/dev/null \
      || { warn "curl/tar missing — skipping mc-router (servers work, the public port does not)"; return 0; }
    url="$(mcrouter_url || true)"
    [ -n "$url" ] || { warn "no mc-router release for $(uname -m) — skipping (servers work, the public port does not)"; return 0; }
    log "installing mc-router from $url ..."
    tmp="$(mktemp -d)"
    if ! curl -fsSL --max-time 120 -o "$tmp/mc-router.tar.gz" "$url" \
       || ! tar -xzf "$tmp/mc-router.tar.gz" -C "$tmp" 2>/dev/null; then
      rm -rf "$tmp"
      warn "mc-router download failed — skipping (servers work, the public port does not)"
      return 0
    fi
    bin="$(find "$tmp" -type f -name mc-router -perm -u+x | head -n1)"
    if [ -z "$bin" ]; then
      rm -rf "$tmp"
      warn "mc-router tarball held no mc-router binary — skipping"
      return 0
    fi
    # root-owned: mc-router runs AS the service user, which must not be able to rewrite its own binary.
    install -m 0755 -o root -g root "$bin" "$ROUTER_BIN"
    rm -rf "$tmp"
  fi

  write_router_unit
  systemctl daemon-reload
  systemctl enable mc-router >/dev/null 2>&1 || true
  systemctl restart mc-router \
    || warn "mc-router failed to start — check 'journalctl -u mc-router' (is $MCROUTER_PORT free?)"
}

write_router_unit() {
  cat > "$ROUTER_UNIT" <<EOF
[Unit]
Description=mc-router — one public Minecraft port for every ${SERVICE_ID} server
Documentation=https://github.com/$MCROUTER_REPO
After=network.target

[Service]
# Unprivileged, and the same account as the daemon: the route table ($ROUTES_FILE) is written by
# mc-router itself, through the REST API on $MCROUTER_API that ${SERVICE_ID}d calls.
User=$SERVICE_USER
Group=$SERVICE_USER
# --connection-rate-limit DEFAULTS TO 1/s, and that default silently breaks the multiplayer screen:
# a client pings EVERY server in its list at once, so a player with a handful of them trips the
# limiter and sees half of them as unreachable. 20/s absorbs that burst and still bounds a flood.
# -routes-config-watch is deliberately NOT passed: its loader is additive, so a route deleted through
# the API comes back on the next reload — a public domain pointing at a recycled port.
ExecStart=$ROUTER_BIN --port $MCROUTER_PORT --api-binding $MCROUTER_API --routes-config $ROUTES_FILE --connection-rate-limit $MCROUTER_RATE_LIMIT
Restart=on-failure
RestartSec=5
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
LockPersonality=yes
RestrictRealtime=yes
# The route table is the only thing it writes.
ReadWritePaths=$STATE_DIR

[Install]
WantedBy=multi-user.target
EOF
}

# ── inline artifact generators ─────────────────────────────────────────────────────
write_unit() {
  cat > "$UNIT" <<EOF
[Unit]
Description=${SERVICE_ID} — game-server hosting (holistic service)
After=network.target holistic-dashboard.service mc-router.service

[Service]
User=$SERVICE_USER
Group=$SERVICE_USER
# Validate the same session as the dashboard via the shared JWT secret.
Environment=HOLISTIC_SECRET_FILE=$HOLISTIC_SECRET_FILE
# Admin = single Linux source of truth (the sudo group by default).
Environment=$ADMIN_ENV=$SERVICE_ADMIN_GROUP
# Sibling services, machine-to-machine. The secrets live in /etc/holistic and are readable by virtue
# of the holistic group (grant_secret_access). A missing secret leaves that integration inert — it
# never takes the daemon down: no notify = no bell when a server changes under a player; no contax =
# contax-kind grants resolve to nobody.
Environment=${ENV_PREFIX}_NOTIFY_URL=$NOTIFY_URL
Environment=${ENV_PREFIX}_NOTIFY_SECRET_FILE=$NOTIFY_SECRET_FILE
Environment=${ENV_PREFIX}_CONTAX_URL=$CONTAX_URL
Environment=${ENV_PREFIX}_CONTAX_SECRET_FILE=$CONTAX_SECRET_FILE
ExecStart=$DAEMON_BIN --listen 127.0.0.1:$SERVICE_PORT
Restart=on-failure
RestartSec=2
# RELAXED, deliberately: this daemon ESCALATES. It shells out to \`sudo -n $WRAPPER\` for every
# OS-level write, and sudo is a setuid binary — NoNewPrivileges=yes would make the setuid bit inert
# and every escalation fail with "effective uid is not 0".
NoNewPrivileges=false
# For the same reason every seccomp-based hardening option is OMITTED (PrivateDevices,
# ProtectKernelTunables/Modules/Logs/Clock, RestrictSUIDSGID, RestrictRealtime, RestrictNamespaces,
# LockPersonality, RestrictAddressFamilies, SystemCallFilter): on a User= unit systemd can only
# install those filters by forcing NoNewPrivileges=yes, which is exactly what must not happen here.
# The namespace-based ones are safe, and are kept.
# ProtectSystem=true, NOT full. The difference is /etc, and it is load-bearing: this daemon escalates
# to \$WRAPPER, which runs useradd/userdel (writing /etc/passwd, /etc/shadow, /etc/group, /etc/subuid
# and their lock files) and installs the per-server systemd drop-in under /etc/systemd/system. The
# wrapper runs via sudo INSIDE this unit's mount namespace, so it inherits these protections. Under
# ProtectSystem=full /etc is read-only there, useradd fails with the misleading "cannot lock
# /etc/passwd; try again later", and every server create dies at account creation — and
# ReadWritePaths=/etc does NOT reliably punch that hole back open for /etc. ProtectSystem=true keeps
# /usr and /boot read-only (the protection that matters) while leaving /etc writable, which is what a
# service that manages system users and units actually needs.
ProtectSystem=true
ProtectHome=true
PrivateTmp=true
# accounts/servers/rcon passwords + every server tree live here.
ReadWritePaths=$STATE_DIR

[Install]
WantedBy=multi-user.target
EOF
}

write_caddy_route() {
  install -d /etc/caddy/conf.d
  cat > "$CADDY_ROUTE" <<EOF
# Generated by \`service setup\`. Routes the service API to the Go daemon. Imported by
# holistic's Caddyfile. Caddy matches this more-specific path (/api/services/$SERVICE_ID/*)
# before the generic /api/* handler regardless of import order, so it wins.
handle /api/services/$SERVICE_ID/* {
	reverse_proxy 127.0.0.1:$SERVICE_PORT
}
EOF
}

# A NOPASSWD-to-root wrapper that is not root-owned or is group/other-writable is an escalation:
# whoever can write it, IS root. Refuse to keep it installed. (holistic/remshel's assert_safe_perms.)
assert_safe_perms() {
  local f owner mode
  for f in "$@"; do
    [ -e "$f" ] || continue
    owner="$(stat -c '%U' "$f")"
    mode="$(stat -c '%a' "$f")"
    [ "$owner" = "root" ] || die "$f not owned by root (owner=$owner)" 4
    if [[ "${mode: -1}" =~ [2367] || "${mode: -2:1}" =~ [2367] ]]; then
      die "$f is group/other-writable (mode=$mode)" 4
    fi
  done
}

# Install the privileged layer + its sudoers drop-in. The daemon may run EXACTLY two commands as
# root: hosuto-server (create/start/stop/restart/destroy/status a server) and hosuto-stop (the RCON
# shutdown). Both re-derive every guard from the kernel and trust nothing they are told, because this
# grant is reachable by anything that gets hold of the service account.
install_wrapper() {
  local src="$REPO_ROOT/sbin/${SERVICE_ID}-server"
  local src_stop="$REPO_ROOT/sbin/${SERVICE_ID}-stop"
  local src_run="$REPO_ROOT/sbin/${SERVICE_ID}-run"
  local f
  for f in "$src" "$src_stop" "$src_run"; do
    [ -f "$f" ] || die "missing $f" 5
  done

  # A server tree is <owner>:$SERVICE_USER 2770 with a default ACL that hands the owner read access
  # to the files the daemon writes into it (server.properties is 0640 and carries the rcon password —
  # the game process, which runs as the owner, has to read it). Without setfacl the wrapper refuses
  # to create a server at all, so pull the package in now rather than fail on the first create.
  command -v setfacl >/dev/null || {
    log "installing acl (the server tree needs POSIX ACLs)..."
    apt-get install -y -qq acl >/dev/null 2>&1 || warn "could not install 'acl' — server creation will refuse to run"
  }

  install -m 0755 -o root -g root "$src" "$WRAPPER"
  install -m 0755 -o root -g root "$src_stop" "$STOP_WRAPPER"
  install -m 0755 -o root -g root "$src_run" "$RUN_WRAPPER"

  # Validate a temp copy before trusting it as a NOPASSWD-to-root grant: a syntax error in
  # /etc/sudoers.d can lock sudo out of the whole host.
  local tmp; tmp="$(mktemp)"
  cat > "$tmp" <<EOF
# Generated by \`service setup\`. ${SERVICE_ID}d runs unprivileged and escalates ONLY to these two
# wrappers. A sudoers command with no argument spec permits ANY arguments — which is what is needed
# (the verb, the owner and the slug are arguments) and why the wrappers re-validate every one of them
# against the kernel: owner must be a real uid>=1000 in smbusers, slug must match the DNS/instance
# grammar, every path is rebuilt under /var/lib/${SERVICE_ID}/servers and realpath-checked.
# Installed root:root 0440 at $SUDOERS (validated by visudo). Never touch /etc/sudoers.d/holistic.
$SERVICE_USER ALL=(root) NOPASSWD: $WRAPPER, $STOP_WRAPPER
EOF
  if ! visudo -cf "$tmp" >/dev/null; then
    rm -f "$tmp"; die "sudoers validation failed" 4
  fi
  install -m 0440 -o root -g root "$tmp" "$SUDOERS"
  rm -f "$tmp"

  assert_safe_perms "$WRAPPER" "$STOP_WRAPPER" "$RUN_WRAPPER" "$SUDOERS"
}

# The per-server template unit. Its instances are hosuto-mc@<owner>-<slug>; the per-instance drop-in
# (User=, the tree, MemoryMax=) is written by hosuto-server create, never from here.
install_mc_unit() {
  local src="$REPO_ROOT/systemd/${SERVICE_ID}-mc@.service"
  [ -f "$src" ] || die "missing $src" 5
  install -m 0644 -o root -g root "$src" "$MC_UNIT"
}

# Declared rights groups, parsed from the manifest (single source of truth).
declared_groups() {
  local src="$REPO_ROOT/permissions/$SERVICE_ID.json"
  [ -f "$src" ] || return 0
  grep -oE '"group"[[:space:]]*:[[:space:]]*"hp_[a-z0-9_-]+"' "$src" | grep -oE 'hp_[a-z0-9_-]+'
}

install_permissions() {
  # Drop the rights manifest where privleg discovers it, and create the backing groups.
  # Each right is admin-only by default (default:false): without privleg the groups stay
  # empty, so behaviour is exactly admin-only. privleg lets an admin grant a non-admin a
  # specific right = add them to the group. The daemon + UI enforce isAdmin || group ∈ groups.
  local src="$REPO_ROOT/permissions/$SERVICE_ID.json"
  [ -f "$src" ] || die "missing $src" 5
  install -d -o "$HOLISTIC_GROUP" -g "$HOLISTIC_GROUP" -m 0755 /etc/holistic/permissions.d 2>/dev/null \
    || install -d -m 0755 /etc/holistic/permissions.d
  install -m 0644 "$src" "$PERMS_FILE"
  local g
  for g in $(declared_groups); do
    groupadd -f "$g"
  done
}

install_config() {
  # The mirror of install_permissions, for the configuration standard: the manifest declares the
  # knobs (zone, port pool, per-member ceilings), the dashboard's central Configuration tab writes
  # the values to /var/lib/holistic/config/<id>.json, and hconfig reads both live — so an admin's
  # edit lands without a restart, and a host with no values file runs on the manifest defaults.
  local src="$REPO_ROOT/config/$SERVICE_ID.json"
  [ -f "$src" ] || die "missing $src" 5
  install -d -o "$HOLISTIC_GROUP" -g "$HOLISTIC_GROUP" -m 0755 /etc/holistic/config.d 2>/dev/null \
    || install -d -m 0755 /etc/holistic/config.d
  install -m 0644 "$src" "$CONFIG_FILE"
}

grant_secret_access() {
  if [ ! -f "$HOLISTIC_SECRET_FILE" ]; then
    warn "$HOLISTIC_SECRET_FILE not found — install the holistic dashboard first"
    return 0
  fi
  getent group "$HOLISTIC_GROUP" >/dev/null \
    || die "group '$HOLISTIC_GROUP' missing — install the dashboard first" 5
  usermod -aG "$HOLISTIC_GROUP" "$SERVICE_USER"   # must succeed or the daemon can't read the secret
  chgrp "$HOLISTIC_GROUP" "$HOLISTIC_SECRET_FILE"
  chmod 0640 "$HOLISTIC_SECRET_FILE"              # scoped to the holistic + service accounts

  # The two machine-to-machine secrets hosuto also reads. They belong to notify and contax; hosuto
  # needs nothing but group read, which the holistic membership above already confers. An absent one
  # is not an error — that integration simply stays inert.
  local f
  for f in "$NOTIFY_SECRET_FILE" "$CONTAX_SECRET_FILE"; do
    if [ -f "$f" ]; then
      chgrp "$HOLISTIC_GROUP" "$f" 2>/dev/null || true
      chmod 0640 "$f" 2>/dev/null || true
    else
      warn "$f not found — that integration stays inert until its service is installed"
    fi
  done
}

# Every running server, so the template unit can be replaced (or removed) without orphaning a JVM.
# Instances are named after their drop-in directory, which hosuto-server create is the only writer of.
mc_instances() {
  local d n
  for d in "$SYSTEMD_DIR/${SERVICE_ID}-mc@"*.service.d; do
    [ -d "$d" ] || continue
    n="$(basename "$d")"
    printf '%s\n' "${n%.service.d}"
  done
}

# ── commands ────────────────────────────────────────────────────────────────────────
cmd_init() {
  local name="${1:-}" old="myservice"
  [ -n "$name" ] || die "usage: ./service init <name>" 2
  [[ "$name" =~ ^[a-z][a-z0-9]{2,19}$ ]] \
    || die "name must be 3–20 chars: lowercase letters and digits, starting with a letter" 2
  [ "$name" = "$old" ] && die "name is already '$old'" 2
  [ -f "$REPO_ROOT/permissions/$old.json" ] \
    || die "this repo is not the pristine template (already initialized?)" 1

  local up; up="$(printf '%s' "$name" | tr '[:lower:]' '[:upper:]')"
  log "renaming '$old' → '$name'..."

  # Rename the daemon command dir and the rights manifest.
  [ -d "$REPO_ROOT/backend/cmd/${old}d" ] && mv "$REPO_ROOT/backend/cmd/${old}d" "$REPO_ROOT/backend/cmd/${name}d"
  mv "$REPO_ROOT/permissions/$old.json" "$REPO_ROOT/permissions/$name.json"

  # Replace identifiers in content files. This CLI is intentionally NOT touched — it
  # auto-detects the id from the manifest filename, so there is nothing to rewrite here.
  local f
  while IFS= read -r -d '' f; do
    sed -i "s/$old/$name/g; s/MYSERVICE/$up/g" "$f"
  done < <(find "$REPO_ROOT/backend" "$REPO_ROOT/ui" "$REPO_ROOT/permissions" \
             -type f \( -name '*.go' -o -name '*.ts' -o -name '*.tsx' -o -name '*.json' -o -name 'go.mod' \) -print0)
  for f in "$REPO_ROOT/README.md" "$REPO_ROOT/CLAUDE.md"; do
    [ -f "$f" ] && sed -i "s/$old/$name/g; s/MYSERVICE/$up/g" "$f"
  done

  log "initialized as '$name'."
  log "next: edit ui/index.tsx displayName + the backend handlers, then 'sudo ./service setup'."
}

cmd_setup() {
  require_id
  needs_root
  local holistic; holistic="$(detect_holistic_repo)" \
    || die "holistic repo not found — set HOLISTIC_REPO=/path/to/holistic" 5
  log "using holistic repo: $holistic"

  log "system user + directories..."
  getent group "$SERVICE_USER" >/dev/null || groupadd --system "$SERVICE_USER"
  getent passwd "$SERVICE_USER" >/dev/null \
    || useradd --system --gid "$SERVICE_USER" --shell /usr/sbin/nologin --home-dir "$STATE_DIR" "$SERVICE_USER"
  # servers/ is only traversed here: each <owner> directory inside it is 0750 and belongs to that
  # human (hosuto-server create), which is what keeps one member out of another's world.
  install -d -o "$SERVICE_USER" -g "$SERVICE_USER" -m 0755 \
    "$SERVICE_APP" "$SERVICE_APP/bin" "$STATE_DIR" "$SERVERS_ROOT"

  build_daemon

  log "granting read on the shared JWT + machine-to-machine secrets..."
  grant_secret_access

  log "installing Java runtimes..."
  ensure_java

  log "installing mc-router (the public Minecraft port)..."
  ensure_mcrouter

  log "installing the privileged wrappers + sudoers..."
  install_wrapper

  log "installing the per-server template unit..."
  install_mc_unit

  log "declaring configuration (config.d)..."
  install_config

  log "configuring systemd..."
  write_unit
  systemctl daemon-reload
  systemctl enable "$SERVICE_ID" >/dev/null 2>&1 || true

  log "adding Caddy route..."
  write_caddy_route

  log "declaring rights (permissions.d) + backing groups..."
  install_permissions

  log "linking UI plugin into holistic + rebuilding dashboard SPA..."
  install -d "$holistic/frontend/external"
  ln -sfn "$REPO_ROOT/ui" "$holistic/frontend/external/$SERVICE_ID"
  # Rebuilds the SPA (now bundling this plugin), recopies www, reinstalls the
  # import-enabled Caddyfile and reloads Caddy — picking up conf.d/$SERVICE_ID.caddy.
  "$holistic/holistic" setup dashboard

  systemctl restart "$SERVICE_ID"
  if ! systemctl is-active --quiet "$SERVICE_ID"; then
    journalctl -u "$SERVICE_ID" -n 20 --no-pager >&2 || true
    die "$SERVICE_ID failed to start" 4
  fi
  log "installed and started — \"$SERVICE_ID\" is live in the holistic sidebar"
}

cmd_build() {
  require_id
  needs_root
  build_daemon
  if systemctl is-active --quiet "$SERVICE_ID"; then
    systemctl restart "$SERVICE_ID"
    log "rebuilt and restarted ${SERVICE_ID}d"
  else
    log "rebuilt ${SERVICE_ID}d (service not running)"
  fi
}

cmd_lifecycle() {
  require_id
  needs_root
  local action="$1"
  systemctl "$action" "$SERVICE_ID" && log "$action: $SERVICE_ID" \
    || die "'$action $SERVICE_ID' failed — installed? run 'sudo $0 setup'"
}

cmd_update() {
  require_id
  log "pulling latest..."
  git -C "$REPO_ROOT" pull --ff-only
  cmd_setup
}

cmd_status() {
  require_id
  local holistic plugin state router javas count running
  state="$(systemctl is-active "$SERVICE_ID" 2>/dev/null || true)"
  router="$(systemctl is-active mc-router 2>/dev/null || true)"
  # The JRE majors versions.JavaBin can pick from.
  javas="$(ls -d /usr/lib/jvm/java-*-openjdk-* 2>/dev/null \
           | sed -n 's#.*/java-\([0-9]\+\)-openjdk.*#\1#p' | sort -rnu | paste -sd, - || true)"
  count="$(mc_instances | wc -l)"
  running="$(systemctl list-units --no-legend --state=active "${SERVICE_ID}-mc@*" 2>/dev/null | wc -l)"
  echo "── $SERVICE_ID (holistic-service-template $TEMPLATE_VERSION) ──"
  printf '  %-16s %s\n' "daemon:" "${state:-unknown}"
  printf '  %-16s %s\n' "listen:" "127.0.0.1:$SERVICE_PORT"
  printf '  %-16s %s\n' "binary:" "$([ -x "$DAEMON_BIN" ] && echo "$DAEMON_BIN" || echo '(not built)')"
  printf '  %-16s %s\n' "unit:"   "$([ -f "$UNIT" ] && echo "$UNIT" || echo missing)"
  printf '  %-16s %s\n' "route:"  "$([ -f "$CADDY_ROUTE" ] && echo "$CADDY_ROUTE" || echo missing)"
  printf '  %-16s %s\n' "rights:" "$([ -f "$PERMS_FILE" ] && echo "$PERMS_FILE" || echo missing)"
  printf '  %-16s %s\n' "config:" "$([ -f "$CONFIG_FILE" ] && echo "$CONFIG_FILE" || echo missing)"
  # The wrappers are the escalation surface: report them as one, and only as "present" when the
  # sudoers grant that makes them reachable is there too.
  printf '  %-16s %s\n' "wrapper:" \
    "$([ -e "$WRAPPER" ] && [ -e "$STOP_WRAPPER" ] && [ -e "$RUN_WRAPPER" ] && [ -f "$SUDOERS" ] \
        && echo "present (+ sudoers)" || echo missing)"
  printf '  %-16s %s\n' "mc unit:" "$([ -f "$MC_UNIT" ] && echo "$MC_UNIT" || echo missing)"
  printf '  %-16s %s\n' "mc-router:" \
    "$([ -x "$ROUTER_BIN" ] && echo "${router:-inactive} (:$MCROUTER_PORT, api $MCROUTER_API)" || echo 'not installed')"
  printf '  %-16s %s\n' "java:"    "${javas:-(none — no server can run)}"
  printf '  %-16s %s\n' "servers:" "$count created, $running running"
  if holistic="$(detect_holistic_repo 2>/dev/null)"; then
    plugin="$holistic/frontend/external/$SERVICE_ID"
    printf '  %-16s %s\n' "plugin:" "$([ -L "$plugin" ] && echo "linked ($holistic)" || echo "missing ($holistic)")"
  else
    printf '  %-16s %s\n' "plugin:" "(holistic repo not found)"
  fi
  if command -v systemctl >/dev/null && [ -f "$UNIT" ]; then
    echo
    echo "── systemctl status $SERVICE_ID ──"
    systemctl --no-pager --lines=3 status "$SERVICE_ID" 2>&1 || true
  fi
}

cmd_uninstall() {
  require_id
  needs_root
  local purge=0
  [ "${1:-}" = "--purge" ] && purge=1
  confirm "remove $SERVICE_ID from this server${purge:+ (and purge the user, $SERVICE_APP and EVERY WORLD in $SERVERS_ROOT)}?" \
    || die "aborted" 10

  # Game servers first: the template unit is about to disappear, and a JVM whose unit is gone is an
  # orphan nobody can stop. Each stop takes the world through an RCON /stop, so this is not instant.
  local inst
  for inst in $(mc_instances); do
    log "stopping $inst..."
    systemctl disable --now "$inst" >/dev/null 2>&1 || true
    systemctl reset-failed "$inst" >/dev/null 2>&1 || true
    rm -rf "${SYSTEMD_DIR:?}/$inst.service.d"
  done

  systemctl disable --now "$SERVICE_ID" >/dev/null 2>&1 || true
  systemctl disable --now mc-router >/dev/null 2>&1 || true
  rm -f "$UNIT" "$MC_UNIT" "$ROUTER_UNIT"; systemctl daemon-reload
  rm -f "$CADDY_ROUTE" "$PERMS_FILE" "$CONFIG_FILE" "$SUDOERS" "$WRAPPER" "$STOP_WRAPPER" "$RUN_WRAPPER"

  local holistic
  if holistic="$(detect_holistic_repo 2>/dev/null)"; then
    rm -f "$holistic/frontend/external/$SERVICE_ID"
    log "rebuilding dashboard SPA without $SERVICE_ID..."
    "$holistic/holistic" setup dashboard || warn "dashboard rebuild failed — run it manually to drop the tab"
  else
    warn "holistic repo not found — remove frontend/external/$SERVICE_ID + rebuild the SPA manually"
  fi

  if [ "$purge" = "1" ]; then
    userdel "$SERVICE_USER" >/dev/null 2>&1 || true
    groupdel "$SERVICE_USER" >/dev/null 2>&1 || true
    local g
    for g in $(declared_groups); do
      groupdel "$g" >/dev/null 2>&1 || true
    done
    # $STATE_DIR holds every world. This is the only place hosuto deletes them wholesale, and it is
    # behind both --purge and the confirmation above.
    rm -rf "$SERVICE_APP" "$STATE_DIR"
    log "purged user, rights groups, $SERVICE_APP, $STATE_DIR (worlds included)"
  else
    log "server worlds kept in $SERVERS_ROOT — 'uninstall --purge' deletes them"
  fi
  log "uninstalled"
}

cmd_help() {
  cat <<EOF
service — CLI for a holistic service (holistic-service-template $TEMPLATE_VERSION).

Usage:
  ./service init <name>          One-time bootstrap: rename the placeholder 'myservice' to
                                 <name> across the repo (module, plugin id, rights group).
  sudo ./service setup           Install/repair as a holistic service: build the daemon, install the
                                 JREs, mc-router, the privileged wrappers + sudoers and the per-server
                                 template unit, wire systemd + Caddy, declare rights + configuration,
                                 link the UI plugin and rebuild the dashboard SPA. Self-elevates.
  sudo ./service build           Rebuild the Go daemon only, then restart if running
  sudo ./service start|stop|restart   Control the daemon (not the game servers)
  ./service status               Show daemon, route, rights, wrappers, mc-router, java and servers
  sudo ./service update          git pull --ff-only + re-run setup
  sudo ./service uninstall [--purge]  Remove (--purge also drops the user, $SERVICE_APP and the worlds)
  ./service help | version

Quickstart:
  ./service init mytool          # rename the placeholder
  sudo ./service setup           # HOLISTIC_REPO is autodetected (sibling ../holistic, /code/holistic, …)

Env (override defaults):
  HOLISTIC_REPO        path to the holistic repo (autodetected if unset)
  SERVICE_PORT         loopback port for the daemon (default $SERVICE_PORT)
  SERVICE_ADMIN_GROUP  Linux group that confers admin (default sudo)
  MCROUTER_PORT        public Minecraft port (default $MCROUTER_PORT)
  SERVICE_YES=1        skip confirmation prompts   ·   SERVICE_QUIET=1  only warnings/errors

Generated artifacts (this script is their source of truth):
  $UNIT
  $CADDY_ROUTE
  $PERMS_FILE
  $CONFIG_FILE
  $SUDOERS
  $ROUTER_UNIT
  $MC_UNIT            (from systemd/${SERVICE_ID}-mc@.service)
  $WRAPPER            (from sbin/${SERVICE_ID}-server)
  $STOP_WRAPPER              (from sbin/${SERVICE_ID}-stop)
  $RUN_WRAPPER               (from sbin/${SERVICE_ID}-run)

Exit codes: 0 ok · 1 generic · 2 usage · 4 external · 5 config-state · 10 declined
EOF
}

# ── dispatch ──────────────────────────────────────────────────────────────────────
main() {
  local cmd="${1:-help}"; shift || true
  case "$cmd" in
    init)                 cmd_init "$@" ;;
    setup)                cmd_setup "$@" ;;
    build)                cmd_build "$@" ;;
    start|stop|restart)   cmd_lifecycle "$cmd" ;;
    status)               cmd_status "$@" ;;
    update)               cmd_update "$@" ;;
    uninstall)            cmd_uninstall "$@" ;;
    version|-v|--version) echo "holistic-service-template $TEMPLATE_VERSION" ;;
    help|-h|--help)       cmd_help ;;
    *) die "unknown command: $cmd (run './service help')" 2 ;;
  esac
}

main "$@"
